{
    "comments": {
        "lineComment": "--"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"],
        ["⟨", "⟩"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "<", "close": ">", "notIn": ["string", "comment"] },
        { "open": "⟨", "close": "⟩", "notIn": ["string", "comment"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"],
        ["⟨", "⟩"],
        ["\"", "\""]
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_'?!\\-]*",
    "indentationRules": {
        "increaseIndentPattern": "\\{\\s*$|\\bdata\\b.*=\\s*$|\\blet\\b.*=\\s*$",
        "decreaseIndentPattern": "^\\s*\\}|\\bin\\b"
    },
    "onEnterRules": [
        {
            "comment": "Continue constructor list with a pipe after an existing pipe line",
            "beforeText": "^(\\s*)(\\|.*)$",
            "action": {
                "indent": "none",
                "appendText": "| "
            }
        },
        {
            "comment": "After 'match <e> return <T> with', start the first case branch",
            "beforeText": "\\bwith\\s*$",
            "action": {
                "indent": "indent",
                "appendText": "| "
            }
        },
        {
            "comment": "After 'let <x> = <e>', dedent and insert 'in '",
            "beforeText": "^\\s*let\\s+\\S.*=\\s*$",
            "action": {
                "indent": "none",
                "appendText": "in "
            }
        }
    ]
}